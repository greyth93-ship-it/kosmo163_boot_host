<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
	
	<mapper namespace="com.winter.app.departments.DepartmentDAO">
		<!-- ID : DAO에서 사용할 메서드명을 ID로 작성 -->
		<!-- 컬럼명과 resultType의 Bean의 Setter이름이 같은걸 찾아줌 -->
		<select id="list" resultType="com.winter.app.departments.DepartmentDTO">
			SELECT * FROM TB_DEPARTMENT
		</select>
		
		<select id="detail" parameterType="java.lang.String" resultType="com.winter.app.departments.DepartmentDTO">
			SELECT * FROM TB_DEPARTMENT WHERE DEPARTMENT_NO = #{num}
		</select>

	</mapper>